{
  "name": "collab-docs-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,WEB -c magenta,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && vite --host 0.0.0.0",
    "build": "cd client && vite build",
    "start": "node server/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "multer": "^1.4.5-lts.1",
    "prisma": "^6.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "supertest": "^7.0.0",
    "vite": "^5.4.10"
  }
}
